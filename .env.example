# Telegram bot token (keep secret, never commit real value)
TELEGRAM_BOT_TOKEN=replace-with-your-bot-token
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/texnik_tgbot
BACKEND_BASE_URL=http://127.0.0.1:8000
BOT_LOCALE=uz
# Optional: path to custom CA certificate bundle for corporate proxy SSL interception
# SSL_CERT_FILE=/path/to/corporate-ca.pem
# Optional debug-only switch to bypass TLS cert verification for Telegram API
# TELEGRAM_INSECURE_SKIP_VERIFY=0
